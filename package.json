{
  "name": "flimify-studio",
  "private": true,
  "version": "0.1.0",
  "description": "AI-native video editor — generate, edit, and export without Premiere. Runs on your own Claude.",
  "author": "Flimify",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "app": "concurrently -k -n vite,electron -c blue,magenta \"vite\" \"wait-on http://localhost:5191 && electron .\"",
    "build": "tsc -b && vite build",
    "build:app": "npm run build && electron-builder",
    "web": "npm run build && node studio-bridge/server.cjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.flimify.studio",
    "productName": "Flimify Studio",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "studio-bridge/**/*"
    ],
    "asarUnpack": [
      "studio-bridge/**",
      "electron/**"
    ],
    "extraResources": [
      { "from": "render", "to": "render" }
    ],
    "directories": { "output": "release", "buildResources": "build" },
    "mac": { "target": "dmg", "category": "public.app-category.video", "icon": "build/icon.icns" },
    "win": { "target": "nsis", "icon": "build/icon.png" },
    "dmg": { "title": "Flimify Studio" }
  },
  "dependencies": {
    "@remotion/player": "^4.0.474",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remotion": "^4.0.474"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
